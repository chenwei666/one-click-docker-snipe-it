@echo off
chcp 65001 >nul
setlocal EnableExtensions

set "ROOT=%~dp0"
if "%ROOT:~-1%"=="\" set "ROOT=%ROOT:~0,-1%"
set "RUNNER=%ROOT%\scripts\ApplyAssetNameRequiredPatch.ps1"
set "TEMP_RUNNER=%TEMP%\SnipeIT-ApplyAssetNameRequiredPatch.ps1"
set "BAT_SELF=%~f0"
set "SNIPEIT_ONECLICK_ROOT=%ROOT%"
set "EXITCODE=0"

cd /d "%ROOT%"

if exist "%RUNNER%" goto run_file
goto run_embedded

:run_file
echo Running Snipe-IT asset-name required patch...
powershell.exe -NoProfile -ExecutionPolicy Bypass -File "%RUNNER%"
set "EXITCODE=%ERRORLEVEL%"
goto done

:run_embedded
echo [WARN] scripts\ApplyAssetNameRequiredPatch.ps1 was not found.
echo [INFO] Using the built-in fallback patch in this bat file...
powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$bat=$env:BAT_SELF; $out=$env:TEMP_RUNNER; $prefix='rem b64:'; $chunks=New-Object System.Collections.Generic.List[string]; foreach($line in [System.IO.File]::ReadLines($bat)){ if($line.StartsWith($prefix)){ $chunks.Add($line.Substring($prefix.Length).Trim()) } }; if($chunks.Count -eq 0){ throw 'embedded payload missing' }; $bytes=[Convert]::FromBase64String(($chunks -join '')); [System.IO.File]::WriteAllBytes($out,$bytes)"
if errorlevel 1 goto extract_failed
powershell.exe -NoProfile -ExecutionPolicy Bypass -File "%TEMP_RUNNER%"
set "EXITCODE=%ERRORLEVEL%"
goto done

:extract_failed
set "EXITCODE=1"
echo [ERROR] Failed to extract the built-in patch runner.
goto done

:done
echo.
if "%EXITCODE%"=="0" (
    echo [OK] Patch command finished.
) else (
    echo [ERROR] Patch command failed. Please send a screenshot of this window.
)
echo.
pause
exit /b %EXITCODE%

goto :eof

